# ============================================================
# FRONTEND ENVIRONMENT VARIABLES — Vercel
# ============================================================
#
# HOW TO USE:
#   1. Copy this file to .env.local for local development
#   2. In Vercel dashboard → Settings → Environment Variables,
#      add VITE_API_BASE_URL with your Render backend URL.
#
# ============================================================

# Your Django backend URL (deployed on Render)
# Example: https://lyn-housing-ai-app-backend.onrender.com/api
VITE_API_BASE_URL=https://YOUR-RENDER-BACKEND-URL.onrender.com/api
