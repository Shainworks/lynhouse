# ============================================================
# BACKEND ENVIRONMENT VARIABLES — Render
# ============================================================
#
# HOW TO USE:
#   1. Copy this file to .env for local development
#   2. In Render dashboard → Environment → Add Environment Variable,
#      add each of the variables below with their actual values.
#
# ============================================================

# Django secret key — generate a strong random one for production
# Run: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-very-strong-secret-key-here

# Set to False in production ALWAYS
DEBUG=False

# Comma-separated list of allowed hosts
# Add your Render URL here (no https://)
ALLOWED_HOSTS=localhost,127.0.0.1,your-backend-name.onrender.com

# PostgreSQL database URL from Render (auto-provided if you use Render Postgres)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Google Gemini API Key
GEMINI_API_KEY=your-gemini-api-key-here

# Comma-separated list of allowed CORS origins (your Vercel frontend URLs)
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app,https://www.lynaihousing.top
